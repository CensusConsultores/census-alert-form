# URL del Web App de Google Apps Script que recibe el POST del formulario.
# Importante: el prefijo PUBLIC_ es lo que la expone al bundle del cliente.
# Esta URL es pública por diseño (el Apps Script está publicado con acceso "Cualquiera"),
# no es un secreto. Pero la dejamos como env var para poder cambiarla sin commit.
PUBLIC_APPS_SCRIPT_URL=https://script.google.com/macros/s/AKfycb..../exec
