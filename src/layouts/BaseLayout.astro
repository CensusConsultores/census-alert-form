---
import "../styles/global.css";
import Banner from "../components/Banner.astro";
import Footer from "../components/Footer.astro";
import LoadingSplash from "../components/LoadingSplash.astro";

interface Props {
  title: string;
  description?: string;
  wrapClass?: string;
  showSplash?: boolean;
}

const {
  title,
  description = "Census Alert · Monitoreo Integral 360° de fuentes oficiales del Estado ecuatoriano.",
  wrapClass = "",
  showSplash = true,
} = Astro.props;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />
    <link rel="icon" type="image/png" href="/alert-icon.png" />
    <link rel="apple-touch-icon" href="/alert-icon.png" />
    <title>{title}</title>
  </head>
  <body>
    {showSplash && <LoadingSplash />}
    <div class={`page-wrap ${wrapClass}`}>
      <Banner />
      <slot />
      <Footer />
    </div>
  </body>
</html>
